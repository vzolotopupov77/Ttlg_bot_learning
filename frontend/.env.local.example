# URL backend API. Для браузерных запросов с cookie лучше тот же hostname, что у вкладки (localhost, не 127.0.0.1).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Должен совпадать с `SECRET_KEY` в backend `.env` — для проверки JWT в middleware (HS256)
AUTH_SECRET=changeme_generate_a_long_random_string

# Базовый URL фронта (для редиректов при необходимости)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
