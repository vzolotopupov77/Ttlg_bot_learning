  "components": {
    "schemas": {
      "AssignmentCreate": {
        "properties": {
          "student_id": {
            "type": "string",
            "format": "uuid",
            "title": "Student Id",
            "description": "UUID ученика"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "title": "Description",
            "description": "Текст задания"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "title": "Due Date",
            "description": "Срок сдачи (дата)"
          },
          "lesson_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lesson Id",
            "description": "Связанное занятие, если есть"
          },
          "status": {
            "$ref": "#/components/schemas/AssignmentStatus",
            "description": "Статус выполнения",
            "default": "pending"
          }
        },
        "type": "object",
        "required": [
          "student_id",
          "description",
          "due_date"
        ],
        "title": "AssignmentCreate"
      },
      "AssignmentRead": {
