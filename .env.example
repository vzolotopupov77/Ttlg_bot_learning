# Скопируйте в .env и подставьте реальные значения. Файл .env не коммитить.
# Положите .env в КОРЕНЬ репозитория (рядом с pyproject.toml).
# Переменные окружения ОС/терминала имеют приоритет над этим файлом.

# Токен бота от @BotFather (формат 123456789:AAH...; кавычки не обязательны)
TELEGRAM_BOT_TOKEN=your_token_here

# Ключ OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# OpenAI-compatible endpoint OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модель в формате OpenRouter (см. каталог на openrouter.ai)
LLM_MODEL=openai/gpt-4o-mini

# Таймаут HTTP-запроса к провайдеру LLM (секунды)
LLM_TIMEOUT_SECONDS=30

LOG_LEVEL=INFO

# --- Backend (FastAPI) ---
# Async PostgreSQL URL для SQLAlchemy + asyncpg (схема обязательна: postgresql+asyncpg://)
# Локально: поднимите БД — make backend-db-up; учётные данные должны совпадать с docker-compose.yml
DATABASE_URL=postgresql+asyncpg://ttlg:ttlg@127.0.0.1:5432/ttlg

# Только для pytest: разрешить sqlite+aiosqlite:// (не использовать в продакшене)
# TTLG_ALLOW_SQLITE_TEST=1

# Сколько последних сообщений диалога держать в памяти на одного пользователя (бот)
HISTORY_DEPTH=20
