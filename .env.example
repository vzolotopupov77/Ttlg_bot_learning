# Скопируйте в .env и подставьте реальные значения. Файл .env не коммитить.
# Положите .env в КОРЕНЬ репозитория (рядом с pyproject.toml).
# Переменные окружения ОС/терминала имеют приоритет над этим файлом.

# --- Telegram-бот (процесс: make run / uv run python -m ttlg_bot) ---
# Токен от @BotFather (формат 123456789:AAH...; кавычки не обязательны)
TELEGRAM_BOT_TOKEN=your_token_here

# Базовый URL backend (бот вызывает только HTTP API, без прямого LLM)
BACKEND_URL=http://127.0.0.1:8000

# Таймаут HTTP-запросов бота к backend (секунды)
# Должен быть больше LLM_TIMEOUT_SECONDS + запас на сеть (рекомендуется 90)
BACKEND_TIMEOUT=90

# --- Backend FastAPI (процесс: make backend-run) ---
# Секрет для подписи JWT (обязателен при старте API; не коммитить реальное значение)
SECRET_KEY=changeme_generate_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Разрешённые origin для браузерного frontend (Next.js на другом хосте/порте). Через запятую.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Учётка преподавателя после `make backend-db-seed` (POST /v1/auth/login, role=teacher)
TEACHER_NAME=Преподаватель
TEACHER_EMAIL=teacher@local.dev
# Пароль для сида (только dev; в prod задать своё)
TEACHER_DEFAULT_PASSWORD=changeme_teacher

# Тестовый ученик (seed alex@example.com) — миграция e1f2a3b4c5d6; вход role=student
# Хэш пишется при первом `alembic upgrade` этой ревизии. Повторный `make backend-db-migrate`
# не пересчитывает пароль. Сменить пароль: см. `docs/tasks/impl/frontend/iteration-6-student-schedule/summary.md`
# (Alembic читает этот файл из корня репо — см. `backend/alembic/env.py`.)
STUDENT_DEFAULT_PASSWORD=changeme_student

# Асинхронный URL SQLAlchemy: PostgreSQL — postgresql+asyncpg://...
# Если не задан — API стартует, GET /health вернёт 503 degraded (БД не настроена)
DATABASE_URL=postgresql+asyncpg://ttlg:ttlg@127.0.0.1:5432/ttlg

# Ключ OpenRouter: https://openrouter.ai/keys (нужен для реальных ответов LLM)
OPENROUTER_API_KEY=your_key_here

# OpenAI-compatible базовый URL OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Идентификатор модели в каталоге OpenRouter (например openai/gpt-4o-mini)
LLM_MODEL=openai/gpt-4o-mini

# Таймаут HTTP-запроса backend к провайдеру LLM (секунды)
LLM_TIMEOUT_SECONDS=30

# URL тестовой БД для pytest (отдельная база ttlg_test в том же контейнере)
# Создать базу: make backend-db-test-create
DATABASE_TEST_URL=postgresql+asyncpg://ttlg:ttlg@127.0.0.1:5432/ttlg_test

# Разрешить sqlite+aiosqlite:// в DATABASE_URL — устарело, оставлено для совместимости
# TTLG_ALLOW_SQLITE_TEST=1

# Уровень логирования (читает и бот, и backend из общего .env: DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
