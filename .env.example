# Скопируйте в .env и подставьте реальные значения. Файл .env не коммитить.
# Положите .env в КОРЕНЬ репозитория (рядом с pyproject.toml).
# Переменные окружения ОС/терминала имеют приоритет над этим файлом.

# Токен бота от @BotFather (формат 123456789:AAH...; кавычки не обязательны)
TELEGRAM_BOT_TOKEN=your_token_here

# Ключ OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# OpenAI-compatible endpoint OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модель в формате OpenRouter (см. каталог на openrouter.ai)
LLM_MODEL=openai/gpt-4o-mini

LOG_LEVEL=INFO

# Сколько последних сообщений диалога держать в памяти на одного пользователя
HISTORY_DEPTH=20
